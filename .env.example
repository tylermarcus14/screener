PORT=3000

# Required for live search mode.
TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=basic
TAVILY_MAX_RESULTS_PER_QUERY=5
TAVILY_MIN_SCORE=0.45
TAVILY_EXACT_MATCH=false

# Optional comma-separated lists. By default the app excludes common social/video
# domains to reduce protected-class and lifestyle noise in HR review.
TAVILY_INCLUDE_DOMAINS=
TAVILY_EXCLUDE_DOMAINS=instagram.com,tiktok.com,linkedin.com,youtube.com,x.com,twitter.com

# Required for AI review. If omitted, the service uses conservative keyword triage.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Defaults to true because this v1 screen runs before first-interview scheduling,
# which may be before a conditional offer.
GAINESVILLE_FAIR_CHANCE_COVERED=true

# Optional shared secret for Zapier. If set, Zapier must send:
# Authorization: Bearer <WEBHOOK_SHARED_SECRET>
WEBHOOK_SHARED_SECRET=
